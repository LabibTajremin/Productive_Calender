# PostgreSQL connection string (Vercel Postgres, Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# Resend (https://resend.com) — used to send reminder/summary emails
RESEND_API_KEY=""
EMAIL_FROM="Momentum <onboarding@resend.dev>"

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>`
# Generate with: openssl rand -base64 32
CRON_SECRET="replace-with-a-random-secret"
